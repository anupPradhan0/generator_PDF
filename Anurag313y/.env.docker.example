# Copy to .env in this folder (Anurag313y/):
#   copy .env.docker.example .env
#
# Local / staging:  docker compose up -d --build
# Production:       docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# --- Required for production (docker-compose.prod.yml) ---
JWT_SECRET=change_this_jwt_secret_in_production

# Public URL users open in the browser (must match CORS)
CLIENT_URL=http://localhost:3000

# MongoDB root credentials (production overlay only)
MONGO_ROOT_USER=eventadmin
MONGO_ROOT_PASSWORD=change_this_mongo_password

# Optional: override Mongo URI for custom setups (dev compose default uses no auth)
# MONGO_URI=mongodb://mongo:27017/invoice_generator

# Host port published for nginx (container listens on 8080)
APP_PORT=3000
