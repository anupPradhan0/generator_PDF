# Environment (secrets) — keep .env.example for templates
.env
.env.local
.env.*.local
**/.env
!**/.env.example

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
build/
**/dist/
**/build/
*.tsbuildinfo

# Generated uploads (PDFs) — keep folder via .gitkeep
**/uploads/*
!**/uploads/.gitkeep

# ML / model weights at Vishalsahani156/models/ (not backend/src/models/ code)
Vishalsahani156/models/*
!Vishalsahani156/models/.gitkeep
*.pt
*.pth
*.onnx
*.h5
*.pkl
*.joblib
*.safetensors
*.bin
*.gguf

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Docker (local overrides only)
docker-compose.override.yml

# Misc
.cache/
.temp/
tmp/
*.pid
.eslintcache
