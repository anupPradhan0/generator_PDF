# --- Local npm dev (backend/frontend on host, Mongo in Docker) ---
# cp .env.example .env
# MONGODB_URI=mongodb://localhost:27017/pdf_generator

# --- Docker Compose (recommended) ---
# All URLs are set in docker-compose.yml — no cloud URLs needed.
# Run: docker compose up -d --build

PORT=5000
NODE_ENV=development

# Docker Compose uses mongodb://mongo:27017/... (see docker-compose.yml)
# Local npm dev uses localhost:
MONGODB_URI=mongodb://localhost:27017/pdf_generator

JWT_SECRET=change-me-please-use-a-long-secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5000
UPLOAD_DIR=uploads
DEEPGRAM_API_KEY=dg_xxx
