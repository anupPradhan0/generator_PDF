# Copy to backend/.env when running: cd backend && npm run dev
# (Project root ../.env is also loaded automatically if this file is missing.)

PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/pdf_generator
JWT_SECRET=change-me-please-use-a-long-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5000
UPLOAD_DIR=uploads
# Get keys: https://console.deepgram.com/ and https://aistudio.google.com/apikey
# GEMINI must start with AIzaSy (Google AI Studio). Do NOT use AQ.* Cloud tokens.
# No quotes around values. Optional: GEMINI_MODEL=gemini-2.0-flash
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GEMINI_API_KEY=AIzaSy_your_ai_studio_key_here


